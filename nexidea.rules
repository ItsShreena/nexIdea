rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Global Safety Net default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Reusable, hardened security primitives
    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function isGuestId(id) {
      return id is string && id.size() <= 128 && id.matches('^guest_[a-zA-Z0-9_\\-]+$');
    }
    
    function incoming() {
      return request.resource.data;
    }
    
    function existing() {
      return resource.data;
    }
    
    function isSignedIn() {
      return request.auth != null;
    }

    // Users collection constraint
    match /users/{userId} {
      allow get: if isSignedIn() && request.auth.uid == userId;
      allow create: if isSignedIn() && request.auth.uid == userId
        && incoming().keys().hasAll(['email', 'createdAt'])
        && incoming().keys().size() == 2
        && incoming().email is string
        && incoming().email.size() <= 128;
    }

    // Startup Analyses collection constraint
    match /startup_analyses/{analysisId} {
      allow get, list: if true;
      
      allow create: if isValidId(analysisId)
        && incoming().keys().hasAll(['userId', 'name', 'ideaDescription', 'overallScore', 'result', 'createdAt'])
        && incoming().keys().size() == 6
        && (incoming().userId == 'anonymous' || isGuestId(incoming().userId) || (isSignedIn() && incoming().userId == request.auth.uid))
        && incoming().name is string
        && incoming().name.size() <= 128
        && incoming().ideaDescription is string
        && incoming().ideaDescription.size() <= 2000
        && incoming().overallScore is number
        && incoming().result is map;
        
      allow delete: if existing().userId == 'anonymous' || isGuestId(existing().userId) || (isSignedIn() && existing().userId == request.auth.uid);
    }
  }
}
